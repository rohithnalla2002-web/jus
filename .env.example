# =============================================================================
# Security & secrets (server-side only — never prefix with VITE_ or commit real
# values to git). Copy this file to `.env` and replace placeholders.
#
# Netlify + Render: see DEPLOYMENT.md (commands, which vars go where — no .env upload).
# =============================================================================

# --- Database (confidential: contains password) ---
# Used by: server/src/db.js, server/scripts/init-db.mjs
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/arcplus

# --- Admin console login (confidential) ---
# Used by: server/src/auth.js — validates POST /api/admin/login
# Change these before any production deployment.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThis_Strong_Password_Immediately

# --- JWT signing key (confidential) ---
# Used by: server/src/auth.js — signs admin session tokens (7-day expiry)
# Generate: openssl rand -hex 32
# Minimum 32 characters; use a long random value in production.
JWT_SECRET=replace_with_openssl_rand_hex_32_minimum_32_chars

# =============================================================================
# Non-secret / operational (optional)
# =============================================================================

# API listen port (default 3001)
# PORT=3001

# Node environment: set to "production" to enforce strong JWT_SECRET
# NODE_ENV=development

# When the Vite dev proxy is not used (e.g. vite preview, static hosting, Netlify),
# set the public API origin so the browser can reach the API (not a secret).
# Netlify: add VITE_API_URL in Site settings → Environment variables, then trigger a new deploy
# (must be present at build time). Example: https://your-api.onrender.com  (no trailing slash).
# VITE_API_URL=http://localhost:3001
Hostname=dpg-d71bpip5pdvs73c5jh70-a
Port=5432
Database=dots_amyi
Username=dots_amyi_user
Password=i6QlAN2LwdHqllcSGV6QEueo8VN9JE7J
Internal Database URL=postgresql://dots_amyi_user:i6QlAN2LwdHqllcSGV6QEueo8VN9JE7J@dpg-d71bpip5pdvs73c5jh70-a/dots_amyi
External Database URL=postgresql://dots_amyi_user:i6QlAN2LwdHqllcSGV6QEueo8VN9JE7J@dpg-d71bpip5pdvs73c5jh70-a.oregon-postgres.render.com/dots_amyi
PSQL Command=PGPASSWORD=i6QlAN2LwdHqllcSGV6QEueo8VN9JE7J psql -h dpg-d71bpip5pdvs73c5jh70-a.oregon-postgres.render.com -U dots_amyi_user dots_amyi